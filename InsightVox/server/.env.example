# Copy this file to .env and fill in your real values. Never commit .env to git.

# MongoDB connection string. For local MongoDB:
#   mongodb://127.0.0.1:27017/insightvox
# For MongoDB Atlas (cloud), use the connection string from your cluster:
#   mongodb+srv://<username>:<password>@<cluster>.mongodb.net/insightvox
MONGO_URI=mongodb://127.0.0.1:27017/insightvox

# Secret used to sign JSON Web Tokens. Use a long random string in production.
JWT_SECRET=change_this_to_a_long_random_secret

# How long a login session lasts
JWT_EXPIRES_IN=7d

# Code that staff must enter when creating a staff account.
# Keep this private and only share it with real staff members.
STAFF_SIGNUP_CODE=change_this_staff_code

# Port the API server runs on
PORT=5000
